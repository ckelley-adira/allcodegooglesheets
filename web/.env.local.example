# =============================================================================
# Adira Reads — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in values.
# NEVER commit .env.local — it contains secrets.
# =============================================================================

# Supabase project credentials (from supabase status or Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Direct Postgres connection for Drizzle migrations and admin queries
# Local dev: Supabase CLI default
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
